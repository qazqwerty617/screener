// Y-axis: price-unit view range (null = auto-fit)
let viewMn = null,
  viewMx = null;
let autoFitY = true; // true = fit to visible candles each frame
let curPH = 600; // chart draw height, updated each frame
let chartState = { mx: 0, mn: 0, pr: 0, PW: 0, PH: 0, TOP: 0, viewStart: 0 };

let isDragX = false,
  dragStartX = 0,
  dragOffX = 0;
let isDragY = false,
  dragStartY = 0,
  dragMnOff = 0,
  dragMxOff = 0;
let mX = -1,
  mY = -1;
let needRebuild = false,
  lastSort = 0,
  lastRender = 0,
  sortedList = [];
let ws = null,
  wsReady = false;
let chartNeedsDraw = false; // set true when live candle updated
const MAX_DIRTY_ROWS_PER_TICK = 240;
const KLINES_CACHE_TTL_MS = 15000;
const KLINES_CACHE = new Map();
let klFetchToken = 0;

// в•ђв•ђв•ђ 240fps Engine via MessageChannel в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
// MessageChannel posts fire faster than setTimeout(0) and are not throttled
// by the browser's 60fps rAF budget вЂ” giving us ~240fps logic ticks.
let INTERP_SPEED = 16.0; // catch-up speed per second (higher = snappier)
const DEFAULT_INTERP_SPEED = 16.0;
const INTERP_SNAP = 0.000005; // snap if within 0.0005% of target
const interpActive = new Set();
let lastTickTs = 0;
let mcRunning = false;
let lastVltRankTs = 0;

// High-frequency tick channel (logic + DOM, not paint)
const _mc = new MessageChannel();
_mc.port2.onmessage = () => {
  const now = performance.now();
  const dt = Math.min((now - lastTickTs) / 1000, 0.05); // max 50ms step
  lastTickTs = now;

  // в”Ђв”Ђ Interpolate all active coins в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  if (interpActive.size > 0) {
    const factor = Math.min(1, INTERP_SPEED * dt);
    const keysToRemove = [];
    for (const key of interpActive) {
      const c = coins.get(key);
      if (!c) {
        keysToRemove.push(key);
        continue;
      }
      if (!c.displayP) {
        c.displayP = c.p;
        keysToRemove.push(key);
        continue;
      }
      const diff = c.p - c.displayP;
      const absDiff = Math.abs(diff);
      const absP = Math.abs(c.p);
      
      if (
        absDiff <= absP * INTERP_SNAP ||
        absDiff < 1e-10
      ) {
        c.displayP = c.p;
        keysToRemove.push(key);
      } else {
        // More physical feel: faster movement for larger jumps
        const step = diff * factor;
        c.displayP += step;
        dirty.add(key);
      }
    }
    keysToRemove.forEach(k => interpActive.delete(k));
  }

  // в”Ђв”Ђ DOM: update dirty rows в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  if (dirty.size > 0 || needRebuild) {
    const now2 = performance.now();
    // Only rebuild every 1000ms even if needRebuild is set (unless it's initial)
    if ((needRebuild || now2 - lastSort > 1000) && (lastSort === 0 || now2 - lastSort > 1000)) {
      rebuildList();
      lastSort = now2;
      needRebuild = false;
    } else {
      let processed = 0;
      for (const key of dirty) {
        updateRow(key);
        dirty.delete(key);
        processed++;
        if (processed >= MAX_DIRTY_ROWS_PER_TICK) break;
      }
    }
    if (needRebuild) dirty.clear();
    lastRender = now2;
  }

  // в”Ђв”Ђ Chart: update last candle with interpolated price в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  const activeKey = `${activeEx}:${activeSym}`;
  const ac = coins.get(activeKey);
  if (
    (chartNeedsDraw || interpActive.has(activeKey)) &&
    ac &&
    candles.length > 0
  ) {
    const last = candles[candles.length - 1];
    const dp = getDisplayP(ac);
    // Only apply displayP if it's close to the candle price (within 20%)
    // This prevents the giant candle bug when switching symbols
    const ratio = last.c > 0 ? dp / last.c : 0;
    if (dp > 0 && ratio > 0.8 && ratio < 1.2) {
      last.c = dp;
      if (dp > last.h) last.h = dp;
      if (dp < last.l) last.l = dp;
    }
    chartNeedsDraw = true; // signal rAF to repaint
  }

  if (chartNeedsDraw) {
    requestDraw();
  }

  // schedule next tick immediately
  if (mcRunning) _mc.port1.postMessage(0);
};

function startMcLoop() {
  if (mcRunning) return;
  mcRunning = true;
  lastTickTs = performance.now();
  _mc.port1.postMessage(0);
}

function scheduleInterp(key) {
  interpActive.add(key);
}

// Use displayP for rendering, real p for logic
const getDisplayP = (c) => c.displayP || c.p;
